# Environment file for the Solid Conformance Test Harness
# when running against solid-community-rs (unauthenticated).
#
# The CTH config validator requires these properties to exist even when
# the server has no authentication.  The webid values are placeholders;
# they are never dereferenced because auth is not enabled.

# Target server - use host.containers.internal so the container can
# reach the server running on the host machine (Podman 4+).
SERVER_ROOT=http://host.containers.internal:3000/

# Alice: the primary test agent (no real credentials needed)
users.alice.webid=http://host.containers.internal:3000/alice/profile/card#me
users.alice.username=alice
users.alice.password=

# Bob: secondary test agent used for WAC/ACL tests (skipped on this server)
users.bob.webid=http://host.containers.internal:3000/bob/profile/card#me
users.bob.username=bob
users.bob.password=

# Origin used in CORS tests
ORIGIN=http://example.org

# Max timeout per scenario in ms
CTH_TIMEOUT=10000
